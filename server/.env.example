GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
SESSION_SECRET=replace_with_a_long_random_string
CLIENT_URL=http://localhost:3000
SERVER_URL=http://localhost:5000

# --- Image generation ----------------------------------------------------------
# Default (no env vars set): IMAGE_PROVIDER_CHAIN=pollinations.
# Activate the full quality+reliability chain by uncommenting below and adding
# the API keys for the providers you've enabled. Providers are tried left to right.
# IMAGE_PROVIDER_CHAIN=realvisxl,cloudflare,huggingface_flux,together,pollinations

# Required when realvisxl OR huggingface_flux is in the chain.
# HUGGINGFACE_API_TOKEN=hf_xxx

# Required when cloudflare is in the chain.
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=

# Required when together is in the chain.
# TOGETHER_API_KEY=

# Storage backend for generated image bytes. 'disk' is the default and survives
# only within a single Node process (Render's free tier wipes disk on redeploy).
# Use 'r2' for durable Cloudflare R2 storage in production.
IMAGE_STORE=disk
IMAGE_CACHE_DIR=./data/image-cache
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=career-predictor-images
